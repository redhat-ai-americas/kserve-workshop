# Example Containerfile for packaging model artifacts for OCI-backed serving.
# Adjust BASE, paths, and USER to match your security policy and runtime expectations.
# Many runtimes expect a versioned folder such as models/1/.

FROM registry.access.redhat.com/ubi9/ubi-micro:latest

COPY models /models

RUN chmod -R a+rX /models

USER 65534

# KServe / runtime will reference oci://...; storage layout must match your ServingRuntime.
